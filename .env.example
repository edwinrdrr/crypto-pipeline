# Local dev config. Copy to .env (gitignored) and load it into your shell with:
#   set -a && source .env && set +a
# (or use `direnv` to auto-load on cd). This just populates env vars on your LAPTOP —
# it points local dbt/ingestion at the DEV environment. It is NOT used by CI or the
# cloud (those inject the same vars via the workflow / --set-env-vars).
#
# Rule of thumb: CONFIG (below) can live here; SECRETS (service-account keys) cannot —
# those go in GitHub Secrets / a secret manager, never in a committed file.

GCP_PROJECT=crypto-pipeline-260527-18241
RAW_BUCKET=crypto-pipeline-260527-18241-crypto-raw

# dbt: which environment local runs target
DBT_METHOD=oauth                      # local auth = gcloud ADC (CI uses service-account)
DBT_TARGET=dev
RAW_DATASET=crypto_raw_dev
DBT_DATASET=crypto_analytics_dev
