# Local dev config — copy to .env (gitignored) and load from the REPO ROOT:
#   set -a && source .env && set +a
#
# Level-3 isolation: each environment is its own GCP PROJECT.
# This .env points your LAPTOP at dev (DBT_TARGET=dev → GCP_PROJECT_DEV).
# CI/cloud don't read this file — they get the same vars from the workflow
# `env:` blocks (per Environment) and the deployed function's --set-env-vars.
# Rule: CONFIG here; SECRETS never (service-account keys → GitHub Secrets / WIF).

# All three project ids (only the dev one is used by default; staging/prod
# are listed so you can switch targets ad-hoc and so the same .env shape works
# everywhere).
GCP_PROJECT_DEV=crypto-pipeline-dev-260528
GCP_PROJECT_STAGING=crypto-pipeline-stg-260528
GCP_PROJECT_PROD=crypto-pipeline-prod-260528

# Local dbt defaults — point at dev.
DBT_TARGET=dev
DBT_METHOD=oauth                 # local auth via gcloud ADC; CI uses WIF (still oauth-method)
DBT_PROFILES_DIR=$PWD/dbt        # resolves to <repo>/dbt when sourced from repo root

# Local ingestion defaults — point at dev's bucket/dataset.
GCP_PROJECT=$GCP_PROJECT_DEV
RAW_BUCKET=$GCP_PROJECT_DEV-crypto-raw
BQ_DATASET=crypto_raw
