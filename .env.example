# Local dev config — the ONE place to set env vars for local runs.
# Copy to .env (gitignored) and load it from the REPO ROOT each shell:
#   set -a && source .env && set +a
#
# This only sets vars on your laptop and points local dbt/ingestion at the DEV
# environment. CI and the cloud do NOT read this file — they inject the same vars
# themselves (workflow `env:`, `--set-env-vars`).
# Rule: CONFIG can live here; SECRETS (service-account keys) cannot — those go in
# GitHub Secrets / a secret manager, never in a committed-style file.

GCP_PROJECT=crypto-pipeline-260527-18241
RAW_BUCKET=crypto-pipeline-260527-18241-crypto-raw

# ingestion (ingestion/main.py): which raw dataset to load into
BQ_DATASET=crypto_raw_dev

# dbt: which environment local runs target
DBT_METHOD=oauth                 # local auth = gcloud ADC (CI uses service-account)
DBT_TARGET=dev
RAW_DATASET=crypto_raw_dev
DBT_DATASET=crypto_analytics_dev
DBT_PROFILES_DIR=$PWD/dbt        # resolves to <repo>/dbt when sourced from the repo root
