# Python
__pycache__/
*.pyc
.venv/
venv/

# Credentials — NEVER commit these
service-account*.json
*-key.json
.env

# Claude Code conversation exports (/export)
20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml          # machine-specific anonymous id
# NOTE: dbt/package-lock.yml IS committed on purpose (pins package versions)

# Airflow (local) runtime — secrets (gcp-key.json, .env) already covered above
airflow/logs/

# Terraform (recursive — multi-env layout)
# NOTE: .terraform.lock.hcl IS committed on purpose (pins provider versions per env).
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
crash.log
crash.*.log

# Other credentials
*-key.json
sa-key.json
